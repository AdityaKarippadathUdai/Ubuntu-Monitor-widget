{
  "name": "desktop-widget",
  "version": "1.0.0",
  "description": "Ubuntu system monitor widget using Electron",
  "main": "main.js",
  "type": "commonjs",
  "author": "Aditya",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "dependencies": {},

  "devDependencies": {
    "electron": "^41.2.1",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-builder": "^24.0.0"
  },

  "build": {
    "appId": "com.aditya.widget",
    "productName": "SystemWidget",

    "files": [
      "**/*"
    ],

    "extraResources": [
      {
        "from": "build/",
        "to": "build/"
      }
    ],

    "directories": {
      "buildResources": "build"
    },

    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}